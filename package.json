{
  "name": "datasheet-to-tscircuit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turn component datasheets into previewable tscircuit TSX with tsci-agent",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"bun --watch src/server/index.ts\" \"vite\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "bun src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tscircuit/3d-viewer": "^0.0.577",
    "@tscircuit/assembly-viewer": "^0.0.6",
    "@tscircuit/create-snippet-url": "^0.0.9",
    "@tscircuit/runframe": "latest",
    "class-variance-authority": "^0.7.1",
    "circuit-json": "latest",
    "cmdk": "^1.1.1",
    "fuse.js": "^7.1.0",
    "jszip": "^3.10.1",
    "ky": "^1.7.5",
    "lucide-react": "latest",
    "posthog-js": "^1.253.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.0.0",
    "react-hot-toast": "^2.5.2",
    "react-query": "^3.39.3",
    "tailwind-merge": "^2.6.0",
    "tsci-agent": "latest",
    "tscircuit": "latest",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "typescript": "^5.9.3",
    "vite": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.9"
}
